# ============================================================
#  Dockerfile — сборка образа для portfolio-app
# ============================================================

# 1. Базовый образ — Node.js LTS на Alpine (лёгкий, ~50 MB)
FROM node:20-alpine

# 2. Рабочая директория внутри контейнера
WORKDIR /app

# 3. Копируем файлы зависимостей и устанавливаем их
#    (отдельно от исходного кода — кэш слоёв Docker)
COPY package.json ./
RUN npm install --omit=dev

# 4. Копируем весь исходный код
COPY . .

# 5. Открываем порт, на котором работает сервер
EXPOSE 3000

# 6. Команда запуска
CMD ["node", "server.js"]
